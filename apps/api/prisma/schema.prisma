generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  premium
}

enum SubscriptionStatus {
  inactive
  active
  past_due
  canceled
  unpaid
  trialing
}

model User {
  id                   String             @id @default(cuid())
  name                 String?
  email                String             @unique
  password             String?
  image                String?
  phone                String?
  location             String?
  cvPath               String?
  cvOriginalName       String?
  cvUploadedAt         DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  plan                 Plan               @default(free)
  subscriptionStatus   SubscriptionStatus @default(inactive)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique

  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  jobs          Job[]
  aiRuns        AIRun[]
  cvProfile     CvProfile?
  connectedAccounts ConnectedAccount[]
  emailLogs         EmailLog[]
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  company     String
  title       String
  email       String?
  coverLetter String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@unique([id, userId])
}

model Job {
  id        String   @id @default(cuid())
  userId    String
  title     String
  company   String
  url       String
  source    String
  applyEmail String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, createdAt])
}

model AIRun {
  id        String   @id @default(cuid())
  userId    String
  type      String
  status    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CvProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  summary   String?
  rawText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ConnectedAccount {
  id                    String   @id @default(cuid())
  userId                String
  provider              String
  email                 String
  accessTokenEncrypted  String   @db.Text
  refreshTokenEncrypted String   @db.Text
  expiresAt             Int
  scope                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model EmailLog {
  id            String    @id @default(cuid())
  userId        String
  applicationId String?
  to            String
  subject       String
  status        String
  provider      String
  sentAt        DateTime?
  errorMessage  String?   @db.Text
  retryCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([applicationId])
}
