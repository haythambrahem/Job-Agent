generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Application {
  id          String   @id @default(cuid())
  company     String
  title       String
  email       String
  coverLetter String
  status      String
  createdAt   DateTime @default(now())
}

model Job {
  id      String @id @default(cuid())
  title   String
  company String
  url     String
  source  String
}
