{
  "name": "job-agent-saas",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @job-agent/api",
    "dev:web": "npm run dev --workspace @job-agent/web",
    "build": "npm run build --workspace @job-agent/core && npm run build --workspace @job-agent/api && npm run build --workspace @job-agent/web",
    "db:generate": "npm run db:generate --workspace @job-agent/api",
    "db:push": "npm run db:push --workspace @job-agent/api"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "next": "^15.5.15",
    "next-auth": "^4.24.14",
    "pino-pretty": "^13.1.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.5"
  }
}
